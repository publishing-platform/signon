<% content_for :title, "Your applications" %>

<div class="row">
  <div class="col-xs-12 col-md-8">
    <% unless current_user.has_2fa? %>
      <div class="alert alert-warning" role="alert">
        <h2 class="alert-heading h4">Make your account more secure</h2>
        <%= render "users/two_factor_authentication/make_your_account_more_secure" %>             
      </div>    
    <% end %>

    <% @applications.each do |application| %>
      <div class="application-list__item">
        <h2 class="h4">
          <%= link_to application.name, application.home_uri %>
        </h2>

        <p class="govuk-body">
          <%= application.description || "No description" %>
        </p>
      </div>
    <% end %>    
  </div>
  <div class="col-xs-12 col-md-4">
    <div class="dashboard-side">
      <h2 class="h4 mb-3">
        Actions and settings
      </h2> 
      
      <ul class="list-group list-group-flush">
        <li class="list-group-item"><%= link_to "Change your email or password", edit_email_or_password_user_path(current_user) %></li>
        <li class="list-group-item"><%= link_to "#{current_user.has_2fa? ? "Change your 2-Factor Authentication phone" : "Set up 2-Factor Authentication"}", two_factor_authentication_path %></li>
      </ul>      
    </div>
  </div>
</div>
<% content_for :title, "Edit #{@user.name}" %>
<% content_for :breadcrumbs do %>
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="<%= root_path %>">Home</a></li>
      <li class="breadcrumb-item"><a href="<%= users_path %>">Users</a></li>
      <li class="breadcrumb-item active" aria-current="page"><%= @user.name %></li>
    </ol>
  </nav>
<% end %>

<p>
  User <strong><%= @user.status %></strong> &bull;
  <%= link_to "#{@user.suspended? ? "Uns" : "S"}uspend user", edit_user_suspensions_path(@user) %> &bull;
  <%= link_to "Manage permissions", user_applications_path(@user) %>
</p>

<% if @user.suspended? and @user.reason_for_suspension.present? %>
  <div class="alert alert-warning" role="alert">
    <h2 class="alert-heading h4">User suspended</h2>
    <em><%= @user.reason_for_suspension %></em>
  </div>
<% end %>

<% if @user.invited_but_not_yet_accepted? %>
  <div class="alert alert-warning" role="alert">
    <h2 class="alert-heading h4">Invitation not accepted yet</h2>
    <p>This user hasn't clicked on the link in their signup mail yet.</p>
    <%= form_tag resend_user_invitation_path(@user), method: :put do %>
      <%= submit_tag "Resend signup email", class: "btn btn-primary" %>     
    <% end %>       
  </div>
<% end %>

<% if @user.access_locked? %>
  <div class="alert alert-warning" role="alert">
    <h2 class="alert-heading h4">Account locked</h2>
    <p>Account has been locked after too many unsuccessful login attempts.</p>
    <p>Locked accounts are automatically unlocked after 1 hour.</p>
    <%= form_tag unlock_user_path(@user), method: :patch do %>
      <%= submit_tag "Unlock account", class: "btn btn-primary" %>
    <% end %>        
  </div>
<% end %>


<% if @user.unconfirmed_email.present? %>
  <div class="alert alert-warning" role="alert">
    <h2 class="alert-heading h4">Pending email change</h2>
    <p>An email has been sent to <strong><%= @user.unconfirmed_email %></strong> with a link to confirm the change.</p>

    <%= form_tag resend_email_change_user_path(@user), method: :put, class: "d-md-inline-block" do %>
      <%= submit_tag "Resend confirmation email", class: "btn btn-primary" %>     
    <% end %>  
    
    <%= form_tag cancel_email_change_user_path(@user), method: :delete, class: "d-md-inline-block" do %>
      <%= submit_tag "Cancel email change", class: "btn btn-danger" %>  
    <% end %>    
  </div>
<% end %>

<% if @user.has_2fa? %>
  <div class="alert alert-warning" role="alert">
    <h2 class="alert-heading h4">Reset 2-Factor Authentication (2FA)</h2>
    <p>Allow user to sign in without a verification code. User will be prompted to set up 2-Factor Authentication again the next time they sign in.</p>

    <%= form_tag reset_2fa_user_path(@user), method: :patch do %>
      <%= submit_tag "Reset 2FA", class: "btn btn-primary" %>     
    <% end %>
  </div>
<% end %>


<div class="row">
  <div class="col-xs-12 col-md-8">
    <%= form_for @user do |f| %>
      <%= render partial: "form_fields", locals: { f: f, resource: @user } %>

      <%= f.submit "Save user", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>

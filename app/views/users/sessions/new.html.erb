<% content_for :title, "Sign in to Publishing Platform" %>

<div class="row">
  <div class="col-xs-12 col-md-6">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { autocomplete: 'on' }) do |f| %>

    <div class="mb-3">
      <%= f.label :email, "Email", class: "form-label" %>
      <%= f.email_field :email, class: "form-control", autofocus: true, tabindex: 0 %>
    </div>

    <div class="mb-3">
      <%= f.label :password, "Password", class: "form-label" %>
      <%= f.password_field :password, class: "form-control" %>    
    </div>     

      <%= f.submit "Sign in", class: "btn btn-primary" %>

    <% end %>

    <p>
      <%= link_to t('devise.links.forgot_password'), new_password_path(resource_name), class: "devgovuk-link" %>
    </p>    
  </div>
</div>
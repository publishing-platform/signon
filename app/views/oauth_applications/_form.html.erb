<%= form_for @application do |f| %>

  <div class="mb-3">
    <%= f.label :name, "Application name", class: "form-label" %>    
    <%= f.text_field :name, class: "form-control", aria: { describedby: (f.object.errors.has_key?(:name) ? "name-errors" : nil) } %>    
    <%= render "components/errors", {
      attribute: :name,
      resource: f.object
    } %>
  </div>      

  <div class="mb-3">
    <%= f.label :description, "Application description", class: "form-label" %>
    <%= f.text_field :description, class: "form-control", aria: { describedby: (f.object.errors.has_key?(:description) ? "description-errors" : nil) } %>    
    <%= render "components/errors", {
      attribute: :description,
      resource: f.object
    } %>
  </div>     

  <div class="mb-3">
    <%= f.label :home_uri, "Application home URL", class: "form-label" %>
    <p id="home_uri-hint" class="fw-light">Used to link to the app on the dashboard</p>
    <%= f.text_field :home_uri, class: "form-control", aria: { describedby: (f.object.errors.has_key?(:home_uri) ? "home_uri-errors home_uri-hint" : "home_uri-hint") } %>    
    <%= render "components/errors", {
      attribute: :home_uri,
      resource: f.object
    } %>
  </div>       

  <div class="mb-3">
    <%= f.label :redirect_uri, "Redirect URI", class: "form-label" %>
    <p id="redirect_uri-hint" class="fw-light">The app should expect this URI. Used in the signin redirect dance.</p>    
    <%= f.text_field :redirect_uri, class: "form-control", aria: { describedby: (f.object.errors.has_key?(:redirect_uri) ? "redirect_uri-errors redirect_uri-hint" : "redirect_uri-hint") } %>    
    <%= render "components/errors", {
      attribute: :redirect_uri,
      resource: f.object
    } %>
  </div>       

  <%= f.submit "Save application", class: "btn btn-primary" %>  

  
<% if false %>

  <% if f.object.persisted? %>
    <%= render "devgovuk_publishing_components/components/input", {
      id: "application_uid",
      label: {
        text: "UID"
      },
      hint: "The app has a copy of this. Used in the signin redirect dance.",  
      name: "application[uid]",
      value: f.object.uid      
    } %>   

    <%= render "devgovuk_publishing_components/components/input", {
      id: "application_secret",
      label: {
        text: "Secret"
      },
      hint: "The app has a copy of this. Used in the signin redirect dance.",  
      name: "application[secret]",
      value: f.object.secret      
    } %>    
    
    <input name="application[retired]" type="hidden" value="0" autocomplete="off">

    <%= render "devgovuk_publishing_components/components/checkboxes", {
      id: "application_retired",
      name: "application[retired]",
      items: [
        {
          label: "This application is retired",
          value: 1,
          checked: f.object.retired?
        }
      ]
    } %> 
    
    <p class="devgovuk-body">
      Retiring an application will hide the application from the dashboard. It will
      not delete data.
    </p>
  <% end %> 

  <%= render "devgovuk_publishing_components/components/button", {
    text: "Save application",
    margin_bottom: true
  } %>
<% end %>

<% end %>
<% content_for :title, "Create new API user" %>
<% content_for :breadcrumbs do %>
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="<%= root_path %>">Home</a></li>
      <li class="breadcrumb-item"><a href="<%= api_users_path %>">API users</a></li>
      <li class="breadcrumb-item active" aria-current="page">Create API user</li>
    </ol>
  </nav>
<% end %>

<div class="row">
  <div class="col-xs-12 col-md-8">
    <%= form_for @api_user do |f| %>
      <%= render partial: "form_fields", locals: { f: f } %>
      <%= f.submit "Create API user", class: "btn btn-primary" %>
    <% end %>    
  </div>
</div>
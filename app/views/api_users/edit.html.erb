<% content_for :title, "Edit #{@api_user.name}" %>

<p>
  User <strong><%= @api_user.status %></strong> &bull;
  <%= link_to "#{@api_user.suspended? ? "Uns" : "S"}uspend user", edit_user_suspensions_path(@api_user) %> &bull;
  <%= link_to "Manage permissions", api_user_applications_path(@api_user) %> &bull;
  <%= link_to "Manage tokens", manage_tokens_api_user_path(@api_user) %>
</p>

<% if @api_user.suspended? and @api_user.reason_for_suspension.present? %>
  <div class="alert alert-warning" role="alert">
    <h2 class="alert-heading h4">User suspended</h2>
    <em><%= @api_user.reason_for_suspension %></em>
  </div>
<% end %>

<div class="row">
  <div class="col-xs-12 col-md-8">
    <%= form_for @api_user do |f| %>
      <%= render partial: "form_fields", locals: { f: f } %>
      <%= f.submit "Save API user", class: "btn btn-primary" %>
    <% end %>    
  </div>
</div>
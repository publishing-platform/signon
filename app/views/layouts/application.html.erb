<html>
  <head>
    <title><%= yield(:title) %> - Publishing Platform Signon</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application" %>    
  </head>  
  <body>  
    
    <div class="container py-3">
      <header class="d-flex flex-wrap align-items-center justify-content-center justify-content-md-between py-3 mb-4 border-bottom">
        <div class="col-md-3 mb-2 mb-md-0">
          <a href="/" class="d-flex align-items-center link-body-emphasis text-decoration-none">
            <span class="fs-4">Signon</span>
          </a>
        </div>
        <%= render "components/navigation", { navigation_items: }%>
      </header>
    
      <main>
        <% if flash["notice"].present? %>
          <p class="alert alert-primary"><%= notice %></p>
        <% end %>
        <% if flash["alert"].present? %>
          <p class="alert alert-danger"><%= alert %></p>
        <% end %>  

        <div class="row">
          <div class="col-xs-12 <%= yield(:top_right).present? ? 'col-md-6' : 'col-md-8' %>">
            <div class="pb-md-4">
              <%= yield(:context) %>
              <h1><%= yield(:title) %></h1>
              <!-- <p class="fs-5 text-body-secondary">Quickly build an effective pricing table for your potential customers with this Bootstrap example. It’s built with default Bootstrap components and utilities with little customization.</p> -->
            </div>               
          </div>
          <% if yield(:top_right).present? %>
            <div class="col-xs-12 col-md-6">
              <%= yield(:top_right) %>
            </div>
          <% end %>             
        </div>

        <%= yield %>        
      </main>
    
